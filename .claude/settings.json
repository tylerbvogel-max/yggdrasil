{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/nasa-lint-hook.sh",
            "timeout": 15,
            "statusMessage": "NASA lint check..."
          }
        ]
      }
    ]
  }
}
